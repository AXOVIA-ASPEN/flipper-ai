# ==================================
# Flipper AI - Production Environment
# ==================================
# NEVER commit real values. Use GCP Secret Manager.
# Pull secrets: make secrets-pull

# ---- Core ----
NODE_ENV="production"

# ---- Database (Cloud SQL via Unix socket) ----
# Runtime connection for Cloud Run (pooling is configured in src/lib/db.ts via PrismaPg adapter):
DATABASE_URL="postgresql://flipper:CHANGE_ME@localhost/flipper_ai?host=/cloudsql/axovia-flipper:us-east1:flipper-ai-postgres"
# Direct connection for migrations (bypasses PrismaPg adapter pool, used by prisma migrate deploy):
DIRECT_DATABASE_URL="postgresql://flipper:CHANGE_ME@CLOUD_SQL_IP/flipper_ai"

# ---- Auth (NextAuth.js) ----
# Generate: openssl rand -base64 32
AUTH_SECRET="CHANGE_ME"
NEXTAUTH_URL="https://your-domain.com"

# ---- Encryption ----
ENCRYPTION_SECRET="CHANGE_ME"

# ---- OAuth Providers ----
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
ENABLE_OAUTH_GOOGLE=false

GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
ENABLE_OAUTH_GITHUB=false

# ---- API Keys ----
OPENAI_API_KEY=""

# ---- Rate Limiting ----
RATE_LIMIT_MAX=60
RATE_LIMIT_WINDOW_MS=60000

# ---- Logging ----
LOG_LEVEL="warn"

# ---- App Version ----
APP_VERSION="1.0.0"

# ---- Monitoring ----
# Internal token for uptime monitors (e.g., UptimeRobot) to access /api/health/metrics
# Generate: openssl rand -hex 32
METRICS_TOKEN="CHANGE_ME"
