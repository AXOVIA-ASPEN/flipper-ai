# ==================================
# Flipper AI - Environment Configuration
# ==================================
# Copy this file to .env.local and fill in your values.
# See src/lib/env.ts for validation schema.
#
# PRODUCTION/STAGING: Secrets are managed via GCP Secret Manager.
# The helpers/secrets.py module loads them at container startup.
# See docs/secrets/secretmanager.md for the full mapping.

# ---- Core ----
NODE_ENV="development"

# ---- Database (PostgreSQL) ----
# Local dev via Cloud SQL Auth Proxy:
DATABASE_URL="postgresql://flipper:PASSWORD@127.0.0.1:5432/flipper_ai"

# ---- Firebase Auth ----
# Client config (public, safe for client bundle)
NEXT_PUBLIC_FIREBASE_API_KEY=""
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="axovia-flipper.firebaseapp.com"
NEXT_PUBLIC_FIREBASE_PROJECT_ID="axovia-flipper"

# Firebase Storage
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET="axovia-flipper.firebasestorage.app"

# Firebase Cloud Messaging (FCM)
# Get messagingSenderId and appId from Firebase Console > Project Settings > General > Your apps
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=""
NEXT_PUBLIC_FIREBASE_APP_ID=""
# VAPID public key from Firebase Console > Cloud Messaging > Web Push certificates
# Base64 string starting with 'B', ~88 characters
NEXT_PUBLIC_FIREBASE_VAPID_KEY=""

# Admin SDK config (server-side only, secret)
# On Cloud Run: ADC provides credentials automatically (no need to set these)
# On local/CI: Set these or use `gcloud auth application-default login`
FIREBASE_CLIENT_EMAIL=""
FIREBASE_PRIVATE_KEY=""

# ---- App URL ----
# Used for generating links in emails, sitemap, Stripe redirects, etc.
# In production this is set via GCP Secret Manager.
APP_URL="http://localhost:3000"

# ---- Encryption ----
# Generate: openssl rand -base64 32
ENCRYPTION_SECRET="your-encryption-secret-here"

# ---- OAuth Providers (Optional) ----
# Google: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
ENABLE_OAUTH_GOOGLE=false

# GitHub: https://github.com/settings/developers
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
ENABLE_OAUTH_GITHUB=false

# Facebook: https://developers.facebook.com/apps/
FACEBOOK_APP_ID=""
FACEBOOK_APP_SECRET=""
FACEBOOK_REDIRECT_URI="http://localhost:3000/api/auth/facebook/callback"
ENABLE_OAUTH_FACEBOOK=false

# ---- Stripe (Payments) ----
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_FLIPPER=""   # Stripe Price ID for Flipper tier
STRIPE_PRICE_PRO=""       # Stripe Price ID for Pro tier

# ---- API Keys ----
OPENAI_API_KEY=""
GOOGLE_API_KEY=""
FLIPPER_API_KEYS=""

# ---- CORS ----
# Comma-separated list of allowed origins for CORS on Cloud Run backend.
# Firebase Hosting rewrites make requests same-origin, so CORS is mainly
# needed for direct Cloud Run access and development.
ALLOWED_ORIGINS="https://axovia-flipper.web.app,https://axovia-flipper.firebaseapp.com,http://localhost:3000"

# ---- E2E Test Auth Bypass ----
# When set, BDD/E2E tests can authenticate without Firebase by setting
# a cookie in the format: test:<secret>:<firebaseUid>
# NEVER set in production. Generate: openssl rand -hex 16
E2E_TEST_SECRET=""

# ---- Rate Limiting ----
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# ---- CAPTCHA (hCaptcha) ----
# Get your keys at: https://www.hcaptcha.com/
NEXT_PUBLIC_HCAPTCHA_SITE_KEY="10000000-ffff-ffff-ffff-000000000001"
HCAPTCHA_SECRET_KEY="0x0000000000000000000000000000000000000000"

# ---- Logging ----
LOG_LEVEL="info"

# ---- Email (Resend) ----
# Get your API key at: https://resend.com/api-keys
RESEND_API_KEY=""
EMAIL_FROM="Flipper AI <notifications@flipper-ai.app>"
APP_URL="http://localhost:3000"

# ---- Error Tracking & Performance (Sentry) ----
# Get your DSN at: https://sentry.io/settings/projects/
# Required for production error tracking and performance monitoring
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""

# Sentry Organization & Project (for source map uploads)
SENTRY_ORG=""
SENTRY_PROJECT=""

# Sentry Auth Token (create at: https://sentry.io/settings/account/api/auth-tokens/)
# Required for uploading source maps in production builds
SENTRY_AUTH_TOKEN=""

# Enable Sentry in development (optional, defaults to false)
# SENTRY_ENABLED="false"

# ---- Monitoring & Notifications (Story 10.1) ----
# API key for Cloud Scheduler → /api/monitoring/run. Store in GCP Secret Manager.
# Minimum 32 characters. Generate: openssl rand -hex 32
MONITORING_API_KEY=""
# Scheduling interval in minutes (matches Cloud Scheduler configuration)
MONITORING_INTERVAL_MINUTES=30
# Number of listings to check per batch within a platform
MONITORING_BATCH_SIZE=20
# Delay between platform-specific batches (ms) — rate-limit avoidance
MONITORING_BATCH_DELAY_MS=1500
# Max retry attempts per individual listing check (2 = 3 total attempts)
MONITORING_MAX_RETRIES=2
# Max listings checked per run — prevents unbounded execution time
MONITORING_MAX_LISTINGS_PER_RUN=500
# Max listing checks per platform per cycle — excess deferred via lastMonitoredAt
MONITORING_MAX_CHECKS_PER_PLATFORM=50
# Hard cap on monitoring run duration (ms). Default: 10 min (must fit Cloud Run 300s timeout)
MONITORING_MAX_RUN_DURATION_MS=600000
# Threshold (ms) after which a RUNNING MonitoringJob is considered stale and reaped
MONITORING_STALE_JOB_TIMEOUT_MS=600000
# Consecutive failures per platform before circuit breaker skips that platform
MONITORING_PLATFORM_FAILURE_THRESHOLD=3
# Percentage of "unavailable" detections that triggers anomaly suppression
MONITORING_ANOMALY_THRESHOLD_PERCENT=30
# Minimum absolute dollar change to generate a price-changed notification
MONITORING_PRICE_CHANGE_MIN_DELTA=1.0
# Minimum percent change to generate a price-changed notification
MONITORING_PRICE_CHANGE_MIN_PERCENT=1
# Deduplication window in minutes — events with the same key within this window are skipped
MONITORING_DEDUP_WINDOW_MINUTES=60
# AbortController timeout per individual platform fetch() call (ms). Prevents hung servers
# from blocking the entire batch indefinitely.
MONITORING_FETCH_TIMEOUT_MS=10000
# Max eBay Browse API calls allocated to monitoring per 24-hour period
# eBay quota is 5,000 calls/day; reserve the rest for regular scraping
EBAY_MONITORING_DAILY_BUDGET=2000

# ---- Notification Processor (Story 10.3) ----
# API key for Cloud Scheduler → /api/notifications/process. MUST be different from MONITORING_API_KEY.
# Minimum 32 characters. Generate: openssl rand -hex 32
NOTIFICATION_PROCESSOR_API_KEY=""
NOTIFICATION_PROCESSOR_BATCH_SIZE=50
NOTIFICATION_PROCESSOR_MAX_RETRIES=3
NOTIFICATION_PROCESSOR_SEND_DELAY_MS=100
NOTIFICATION_PROCESSOR_MAX_DURATION_MS=240000
NOTIFICATION_PROCESSOR_MAX_EMAILS_PER_USER_PER_HOUR=10
NOTIFICATION_PROVIDER_FAILURE_THRESHOLD=3
NOTIFICATION_MAX_EVENT_AGE_HOURS=48
OPPORTUNITY_DIGEST_THRESHOLD=5

# ---- Twilio SMS Notifications (Story 11.2) ----
# Twilio Account SID (starts with "AC"). Get it at: https://console.twilio.com/
TWILIO_ACCOUNT_SID=""
# Twilio Auth Token. Store in GCP Secret Manager for production.
TWILIO_AUTH_TOKEN=""
# Twilio-purchased phone number in E.164 format (e.g., +12025550100)
TWILIO_FROM_NUMBER=""

# ---- Google Maps Directions API (Story 12.2) ----
# Enables driving route calculation for meetup departure reminders.
# Create a Directions API key at: https://console.cloud.google.com/apis/credentials
# Enable the "Directions API" on the same GCP project.
# Restrict to: Directions API, IP allow-list (Cloud Run egress IPs).
# Production: store in GCP Secret Manager as "GOOGLE_MAPS_API_KEY".
GOOGLE_MAPS_API_KEY=""

# ---- Google Calendar Integration (Story 12.1) ----
# Create credentials at: https://console.cloud.google.com/apis/credentials
# OAuth 2.0 Client ID (Web Application type). Add the redirect URI below
# exactly (character-for-character) to the Authorized Redirect URIs list.
GOOGLE_CALENDAR_CLIENT_ID=""
GOOGLE_CALENDAR_CLIENT_SECRET=""
GOOGLE_CALENDAR_REDIRECT_URI="http://localhost:3000/api/integrations/google-calendar/callback"

# ---- Marketplace Scrapers ----
# eBay Browse API OAuth token (Story 3.2)
EBAY_OAUTH_TOKEN=""
EBAY_BROWSE_API_BASE_URL="https://api.ebay.com/buy/browse/v1"
EBAY_MARKETPLACE_ID="EBAY_US"

# ---- Logistics & Shipping (Story 5.5) ----
# Shippo — carrier rate estimation (USPS, UPS, FedEx)
# Get your token at: https://goshippo.com/user/apikeys/
SHIPPO_API_TOKEN=""
# ZIP code used as the ship-from origin for rate estimates
SHIPPO_FROM_ZIP="10001"

# Geoapify — geocoding for local pickup distance calculation
# Get your key at: https://myprojects.geoapify.com/
GEOAPIFY_API_KEY=""
